# llm-usage-mcp example environment file
#
# Copy to `.env` (gitignored) and fill in the values you need.
# Every key shown here is optional; defaults are noted inline.
# Full reference: docs/configuration.md

# --- general ---------------------------------------------------------------

# SQLAlchemy URL for the local usage database.
# Default: sqlite:///$HOME/.llm-usage/usage.db
# LLM_USAGE_DB_URL=sqlite:///./usage.db

# Log level for the server + library. One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Default: INFO
# LLM_USAGE_LOG_LEVEL=INFO

# When true, the capture layer stores full request/response prompts in metadata.
# Off by default for privacy; turn on only when debugging captures.
# LLM_USAGE_LOG_PROMPTS=0

# TCP port for the capture proxy (Path A in docs/spec.md). Bound to
# 127.0.0.1 only (loopback) — never reachable from the network.
# Default: 5525
# LLM_USAGE_PROXY_PORT=5525

# Comma-separated list of providers the proxy / capture layer will serve.
# Default: anthropic,openai,qwen,deepseek (every v1 provider).
# `Settings.require_keys()` refuses to start if a listed provider's key is missing.
# LLM_USAGE_ENABLED_PROVIDERS=anthropic,openai,qwen,deepseek

# --- per-provider base URLs ------------------------------------------------
#
# Useful for self-hosted gateways, regional endpoints, and test doubles.

# LLM_USAGE_ANTHROPIC_BASE_URL=https://api.anthropic.com
# LLM_USAGE_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_USAGE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_USAGE_DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- per-provider API keys -------------------------------------------------
#
# These use the SDK-standard env var names so they coexist with the official
# Anthropic / OpenAI / Qwen / DeepSeek clients you may already have set up.
# Never commit real values. Treat this file as a template only.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DASHSCOPE_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
